#!/usr/bin/env bash
# Mock aquadirector binary for demo recording.
# Used by hack/demo.tape тАФ not for production use.

CMD="$*"

case "$CMD" in
  dashboard)
    # ANSI escapes for the colorized dashboard demo. Palette matches
    # internal/color: bold=1, dim=2, red=31, green=32, yellow=33, blue=34.
    B=$'\e[1m'; D=$'\e[2m'; R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; X=$'\e[0m'
    cat <<EOF

${B}=== Water Quality ===${X}
${D}pH${X}           7.87  (${Y}low${X})
${D}Temperature${X}  25.4C / 77.7F
${D}ORP${X}          155 mV  (${Y}low${X})
${D}Salinity${X}     0.63%
${D}SG${X}           1.022

${B}=== ATO ===${X}
${D}Status${X}       auto  (level=desired, 5.0 gal)  temp=25.5C
${D}Pump${X}         off  last trigger: manual
${D}Today Fills${X}  6  (0.22 gal)
${D}Last Fill${X}    2026-04-11 17:14
${D}Temp 7d${X}      min=24.8C  avg=25.4C  max=26.6C
${D}Leak Sensor${X}  ${G}dry${X}

${B}=== Lighting ===${X}
${D}Mode${X}         auto  (moon=0, white=46, blue=65)

${B}=== Feeding ===${X}
${D}Food${X}         ~0g  drum=${R}RED${X}  (level=0)

${B}=== Notifications (last 7 days) ===${X}
${D}2026-04-11 08:51${X}  ATO: Reservoir is running low.

Ran at 2026-04-11 17:14:32
EOF
    ;;

  "sensor status --output json")
    cat <<'EOF'
{
  "run_at": 1744398263,
  "ph": 7.87,
  "temperature_c": 25.4,
  "temperature_f": 77.7,
  "orp_mv": 155,
  "salinity_pct": 0.63,
  "sg": 1.022,
  "tds_ppm": 412,
  "ec_us_cm": 52100,
  "battery_pct": 85
}
EOF
    ;;

  "alerts check")
    cat <<'EOF'
OK      critical  temperature_high
OK      warning   temperature_low
OK      critical  leak_detected
FIRING  warning   ph_low           pH is 7.87 (below 7.8)
FIRING  warning   feeder_drum_low  Autofeeder drum is low (state=2)

Ran at 2026-04-11 17:14:32
EOF
    ;;

  *)
    echo "aquadirector: unknown command '$CMD'" >&2
    exit 1
    ;;
esac
